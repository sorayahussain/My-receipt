rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedEmail() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerifiedOwner(userId) {
      return isVerifiedEmail() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'createdAt']) 
        && data.keys().size() == 4 // userId, email, displayName, createdAt
        && data.userId == request.auth.uid
        && data.email is string
        && data.createdAt == request.time;
    }

    function isValidReceipt(data) {
      return data.keys().hasAll(['merchantName', 'date', 'totalAmount', 'currency', 'ownerId', 'createdAt', 'category', 'lineItems'])
        && data.merchantName is string && data.merchantName.size() <= 200
        && data.category is string && data.category.size() <= 100
        && data.date is string && data.date.size() == 10
        && data.totalAmount is number && data.totalAmount >= 0
        && data.currency is string && data.currency.size() == 3
        && data.ownerId == request.auth.uid
        && data.lineItems is list
        && (data.get('merchantAddress', null) == null || (data.merchantAddress is string && data.merchantAddress.size() < 500))
        && (data.get('summary', null) == null || (data.summary is string && data.summary.size() < 500))
        && (data.get('imageUrl', null) == null || (data.imageUrl is string && data.imageUrl.size() < 2000));
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
        && isValidUser(incoming());
      allow delete: if isOwner(userId);

      match /receipts/{receiptId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidReceipt(incoming()) && incoming().createdAt == request.time;
        allow update: if isOwner(userId) 
          && incoming().diff(existing()).affectedKeys().hasOnly(['merchantName', 'date', 'totalAmount', 'currency', 'imageUrl', 'merchantAddress', 'category', 'summary', 'lineItems'])
          && isValidReceipt(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
